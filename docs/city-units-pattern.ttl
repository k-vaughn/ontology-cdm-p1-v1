@prefix cc: <http://creativecommons.org/ns#> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix i72: <https://w3id.org/citydata/21972/v1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <https://w3id.org/citydata/part1/v1/> .
<https://w3id.org/citydata/part1/v1/CityUnitsPattern/>  rdf:type  owl:Ontology;
        dcterms:title                  "Information technology - City data model - Part 1: Foundation level concepts - City Units Pattern";
        dcterms:alternative            "CDM City Units Pattern";
        skos:definition                "This ontology specifies the foundation-level concepts related to the city units pattern of the city data model.";
        vann:preferredNamespaceUri     "https://w3id.org/citydata/part1/v1/";
        vann:preferredNamespacePrefix  "cdm1";
        dcterms:creator                "Megan Katsumi";
        dcterms:creator                "Mark Fox";
        dcterms:creator                "Kenneth Vaughn";
        rdfs:comment                   "The prior version of this ontology used a different ontology IRI. This update remains semantically consistent with the version adopted as ISO 5087-1:2023.";
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/CityUnits/>;
        dcterms:modified               "2026-02-12"^^xsd:date;
        owl:versionInfo                "1.3.0";
        owl:versionIRI                 <CityUnitsPattern/r3.0/>;
        cc:license                     "http://creativecommons.org/licenses/by/4.0/";
        owl:imports                    i72:;
        owl:imports <https://w3id.org/citydata/part1/v1/Core> .

cdm1:CityUnitObjectProperty
        rdf:type            owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:FoundationalCdmObjectProperty;
        skos:definition     "Added for organizational purposes, to identify all city unit object properties defined in the City Data Model." .

cdm1:CityUnitsDataProperty
        rdf:type            owl:DatatypeProperty;
        skos:definition     "Added for organizational purposes, to identify data properties defined in the City Units Pattern of the CDM ontology.";
        rdfs:subPropertyOf  cdm1:FoundationalCdmDataProperty .

cdm1:hasRelativeYear  rdf:type  owl:DatatypeProperty;
        skos:definition     "The base year used to define monetary values for a currency.";
        rdfs:subPropertyOf  cdm1:CityUnitsDataProperty;
        rdfs:range          xsd:gYear .

cdm1:CityUnitsThing  rdf:type  owl:Class;
        rdfs:comment     "Added for organizational purposes to group the classes defined in the City Units portion of the CDM.";
        rdfs:subClassOf  cdm1:FoundationalCdmThing .

cdm1:Acceleration  rdf:type  owl:Class;
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  _:b0 .

_:b0    rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b1 .

_:b1    rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  cdm1:AccelerationUnit .

cdm1:Acceleration  rdfs:label  "acceleration" .

cdm1:AccelerationUnit  rdf:type  owl:Class;
        rdfs:subClassOf  i72:Unit_of_measure;
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:label       "acceleration unit" .

cdm1:AmountOfMoney  rdf:type  owl:Class;
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  _:b2 .

_:b2    rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b3 .

_:b3    rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  i72:Monetary_unit .

cdm1:AmountOfMoney  rdfs:label  "amount of money" .

cdm1:Area   rdf:type         owl:Class;
        skos:definition  "Area expresses the two-dimensional size of a defined part of a surface, typically a region bounded by a closed curve. It is a derived quantity in the International System of Units. Area is length squared.";
        rdfs:label       "area";
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  _:b4 .

_:b4    rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b5 .

_:b5    rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  cdm1:AreaUnit .

cdm1:AreaUnit  rdf:type      owl:Class;
        skos:definition  "Unit of area in the specified system of units.";
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  i72:Unit_of_measure;
        rdfs:label       "area unit" .

cdm1:Capacity  rdf:type      owl:Class;
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  _:b6 .

_:b6    rdf:type            owl:Restriction;
        owl:onProperty      i72:defined_by;
        owl:minCardinality  "1"^^xsd:nonNegativeInteger .

cdm1:CapacitySize  rdf:type  owl:Class;
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  _:b7 .

_:b7    rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b8 .

_:b8    rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  i72:Cardinality_unit .

cdm1:CapacitySize  rdfs:subClassOf  _:b9 .

_:b9    rdf:type                  owl:Restriction;
        owl:onProperty            i72:cardinality_of;
        owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger;
        owl:onClass               cdm1:Capacity .

cdm1:CardinalityMeasure  rdf:type  owl:Class;
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  i72:Measure;
        rdfs:subClassOf  _:b10 .

_:b10   rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  i72:Cardinality_unit .

cdm1:CardinalityUnitPerTime
        rdf:type         owl:Class;
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  i72:Unit_division;
        rdfs:subClassOf  _:b11 .

_:b11   rdf:type           owl:Restriction;
        owl:onProperty     i72:denominator;
        owl:allValuesFrom  cdm1:TimeUnit .

cdm1:CardinalityUnitPerTime
        rdfs:subClassOf  _:b12 .

_:b12   rdf:type           owl:Restriction;
        owl:onProperty     i72:numerator;
        owl:allValuesFrom  i72:Cardinality_unit .

cdm1:Duration  rdf:type      owl:Class;
        skos:definition  "Duration is the amount of time that elapses between two instants or events.";
        rdfs:label       "duration";
        rdfs:subClassOf  cdm1:CityUnitsThing;
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  time:TemporalDuration;
        rdfs:subClassOf  _:b13 .

_:b13   rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b14 .

_:b14   rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  cdm1:TimeUnit .

cdm1:Geo_Position_unit  rdf:type  owl:Class;
        rdfs:subClassOf  i72:Unit_of_measure;
        rdfs:comment     "Reference systems to indicate geographic position." .

cdm1:Length  rdf:type        owl:Class;
        skos:definition  "Length is the amount of space between two geographical points along a curve. It is a base quantity in the International System of Units and other systems of units. Length is speed times time. The metre, a base unit of length in the International System of Units, is defined in terms of speed of light during a certain time interval.";
        rdfs:label       "length";
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  _:b15 .

_:b15   rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b16 .

_:b16   rdf:type            owl:Class;
        owl:intersectionOf  _:b17 .

_:b17   rdf:first  i72:Measure;
        rdf:rest   _:b18 .

_:b18   rdf:first  _:b19 .

_:b19   rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  cdm1:LengthUnit .

_:b18   rdf:rest  rdf:nil .

cdm1:LengthUnit  rdf:type    owl:Class;
        skos:definition  "A specified system of units for distance.";
        rdfs:subClassOf  i72:Unit_of_measure;
        rdfs:label       "length unit" .

cdm1:Mass   rdf:type         owl:Class;
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  _:b20 .

_:b20   rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b21 .

_:b21   rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  cdm1:MassUnit .

cdm1:Mass   rdfs:comment  "Mass is the amount of matter of a phenomenon. It is a base quantity in the International System of Units. Mass is force divided by acceleration.";
        rdfs:label    "mass" .

cdm1:MassUnit  rdf:type      owl:Class;
        rdfs:subClassOf  i72:Unit_of_measure;
        rdfs:label       "mass unit" .

cdm1:MonetaryValue  rdf:type  owl:Class;
        skos:definition  "A Monetary Value has a numerical value that is relative to a particular date (year). A Monetary Value is measured with some currency.";
        rdfs:subClassOf  i72:Measure;
        rdfs:subClassOf  _:b22 .

_:b22   rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  i72:Monetary_unit .

cdm1:MonetaryValue  rdfs:subClassOf  _:b23 .

_:b23   rdf:type                  owl:Restriction;
        owl:onProperty            cdm1:hasRelativeYear;
        owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger;
        owl:onDataRange           xsd:gYear .

cdm1:Ratio  rdf:type         owl:Class;
        skos:definition  "A ratio is a comparison of two quantities, often expressed as a fraction or in the form a:b.";
        rdfs:subClassOf  i72:Quantity;
        rdfs:label       "ratio" .

cdm1:Speed  rdf:type         owl:Class;
        skos:definition  "Speed is the time rate of motion measured by the distance moved over in unit time.";
        rdfs:label       "speed";
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  _:b24 .

_:b24   rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b25 .

_:b25   rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  cdm1:SpeedUnit .

cdm1:SpeedUnit  rdf:type     owl:Class;
        skos:definition  "A specified system of units for speed.";
        rdfs:subClassOf  i72:Unit_of_measure;
        rdfs:label       "speed unit" .

cdm1:TimeUnit  rdf:type      owl:Class;
        skos:definition  "A specified system of units for time.";
        rdfs:subClassOf  i72:Unit_of_measure;
        rdfs:label       "time unit" .

cdm1:ValueOfMoney  rdf:type  owl:Class;
        skos:definition  "An amount of money that is defined relative to a particular year.";
        rdfs:subClassOf  cdm1:AmountOfMoney;
        rdfs:subClassOf  _:b26 .

_:b26   rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  cdm1:MonetaryValue .

cdm1:Volume  rdf:type        owl:Class;
        skos:definition  "Volume is a measure of how much three-dimensional space any phenomenon occupies. ";
        rdfs:label       "volume";
        rdfs:subClassOf  i72:Quantity;
        rdfs:subClassOf  _:b27 .

_:b27   rdf:type           owl:Restriction;
        owl:onProperty     i72:value;
        owl:allValuesFrom  _:b28 .

_:b28   rdf:type           owl:Restriction;
        owl:onProperty     i72:unit_of_measure;
        owl:allValuesFrom  cdm1:VolumeUnit .

cdm1:VolumeUnit  rdf:type    owl:Class;
        skos:definition  "A specified system of units for volume.";
        rdfs:subClassOf  i72:Unit_of_measure;
        rdfs:label       "volume unit" .
