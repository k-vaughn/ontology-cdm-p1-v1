@prefix : <https://w3id.org/citydata/part1/v1/> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix i72: <https://w3id.org/citydata/21972/v1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<https://w3id.org/citydata/part1/v1/ResourcePattern/shacl>
    rdf:type owl:Ontology ;
    dcterms:title "City Data Model Part 1 - Resource Pattern - SHACL constraints" ;
    skos:definition "SHACL validation shapes for the Resource Pattern pattern module." ;
    vann:preferredNamespaceUri "https://w3id.org/citydata/part1/v1/" ;
    vann:preferredNamespacePrefix "cdm1" ;
    owl:imports :ResourcePattern ;
    owl:imports <https://w3id.org/citydata/part1/v1/Core/shacl> .

:PlannedAllocationShape
    rdf:type sh:NodeShape ;
    sh:targetClass :PlannedAllocation ;
    sh:property [
        sh:path time:hasTime ;
        sh:node :ExactlyOneShape ;
        sh:class time:TemporalEntity
    ] ;
    sh:property [
        sh:path :hasQuantity ;
        sh:node :ExactlyOneShape ;
        sh:class i72:Quantity
    ] ;
    sh:property [
        sh:path :forResource ;
        sh:node :ExactlyOneShape ;
        sh:class :Resource
    ] ;
    sh:property [
        sh:path :forState ;
        sh:node :ExactlyOneShape ;
        sh:class :State
    ] .

:ResourceShape
    rdf:type sh:NodeShape ;
    sh:targetClass :Resource ;
    sh:property [
        sh:path :hasAllocation ;
        sh:class :PlannedAllocation
    ] ;
    sh:property [
        sh:path :hasLocation ;
        sh:class :Location
    ] ;
    sh:property [
        sh:path :hasAvailableCapacity ;
        sh:node :ExactlyOneShape ;
        sh:class i72:Quantity
    ] ;
    sh:property [
        sh:path :participatesIn ;
        sh:node :MinOneShape ;
        sh:class :Activity
    ] ;
    sh:property [
        sh:path :hasCapacity ;
        sh:node :ExactlyOneShape ;
        sh:class i72:Quantity
    ] ;
    sh:property [
        sh:path :capacityInUse ;
        sh:node :ExactlyOneShape ;
        sh:class i72:Quantity
    ] .

:TerminalResourceStateShape
    rdf:type sh:NodeShape ;
    sh:targetClass :TerminalResourceState ;
    sh:property [
        sh:path :hasResource ;
        sh:class :Resource
    ] ;
    sh:property [
        sh:path :hasAllocation ;
        sh:class :PlannedAllocation
    ] ;
    sh:property [
        sh:path :hasQuantity ;
        sh:class i72:Quantity
    ] .
