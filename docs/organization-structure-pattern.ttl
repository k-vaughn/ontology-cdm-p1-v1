@prefix cc: <http://creativecommons.org/ns#> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <https://w3id.org/citydata/part1/v1/> .
<https://w3id.org/citydata/part1/v1/OrganizationStructurePattern/>  rdf:type  owl:Ontology;
        dcterms:title                  "Information technology - City data model - Part 1: Foundation level concepts - Organization Structure Pattern";
        dcterms:alternative            "CDM Organization Structure Pattern";
        skos:definition                "This ontology specifies the foundation-level concepts related to the organization structure pattern of the city data model.";
        vann:preferredNamespaceUri     "https://w3id.org/citydata/part1/v1/";
        vann:preferredNamespacePrefix  "cdm1";
        dcterms:creator                "Megan Katsumi";
        dcterms:creator                "Mark Fox";
        dcterms:creator                "Kenneth Vaughn";
        rdfs:comment                   "The prior version of this ontology used a different ontology IRI. This update remains semantically consistent with the version adopted as ISO 5087-1:2023.";
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/OrganizationStructure/>;
        dcterms:modified               "2026-02-12"^^xsd:date;
        owl:versionInfo                "1.3.0";
        owl:versionIRI                 <OrganizationStructurePattern/r3.0/>;
        cc:license                     "http://creativecommons.org/licenses/by/4.0/";
        owl:imports <https://w3id.org/citydata/part1/v1/AgentPattern/> ;
        owl:imports                    org: .

cdm1:OrganizationThing  rdf:type  owl:Class;
        skos:definition  "A class representing an organization in the context of the CDM ontology.";
        rdfs:subClassOf  cdm1:FoundationalCdmThing .

cdm1:Organization  rdf:type  owl:Class;
        skos:definition  "A collection of people organized together into a community or other social, commercial or political structure. The group has some common purpose or reason for existence which goes beyond the set of people belonging to it. An organization may itself be able to act as an agent.\n        In addition to the standard org:Organization pattern, this ontology defines an cdm1:Organization to be a subclass of an cdm1:Agent.";
        rdfs:subClassOf  cdm1:Agent;
        rdfs:subClassOf  cdm1:OrganizationThing;
        rdfs:subClassOf  org:Organization .
