        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/CityUnits/>;
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/>;
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Mereology/>;
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/OrganizationStructure/>;
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/RecurringEvent/>;
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Resource/>;
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/SpatialLoc/>;
        dcterms:modified               "2026-02-12"^^xsd:date;
