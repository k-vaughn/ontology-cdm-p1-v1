@prefix cc: <http://creativecommons.org/ns#> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <https://w3id.org/citydata/part1/v1/> .
<https://w3id.org/citydata/part1/v1/AgentPattern/>  rdf:type  owl:Ontology;
        dcterms:title                  "Information technology - City data model - Part 1: Foundation level concepts - Agent Pattern";
        dcterms:alternative            "CDM Agent Pattern";
        skos:definition                "This ontology specifies the foundation-level concepts related to the agent pattern of the city data model.";
        vann:preferredNamespaceUri     "https://w3id.org/citydata/part1/v1/";
        vann:preferredNamespacePrefix  "cdm1";
        dcterms:creator                "Megan Katsumi";
        dcterms:creator                "Mark Fox";
        dcterms:creator                "Kenneth Vaughn";
        rdfs:comment                   "The prior version of this ontology used a different ontology IRI. This update remains semantically consistent with the version adopted as ISO 5087-1:2023.";
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Agent/>;
        dcterms:modified               "2026-02-12"^^xsd:date;
        owl:versionInfo                "1.3.0";
        owl:versionIRI                 <AgentPattern/r3.0/>;
        cc:license                     "http://creativecommons.org/licenses/by/4.0/";
        owl:imports <https://w3id.org/citydata/part1/v1/GenericPropertiesPattern/> ;
        owl:imports <https://w3id.org/citydata/part1/v1/ResourcePattern/> .

cdm1:AgentObjectProperty  rdf:type  owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:FoundationalCdmObjectProperty;
        skos:definition     "Added for organizational purposes, to identify all agent object properties defined in the City Data Model." .

cdm1:performedBy  rdf:type      owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:AgentObjectProperty;
        owl:inverseOf       cdm1:performs .

cdm1:performs  rdf:type         owl:ObjectProperty;
        skos:definition     "Identifies activities that the Agent performs.";
        rdfs:subPropertyOf  cdm1:AgentObjectProperty;
        rdfs:domain         cdm1:Agent;
        rdfs:range          cdm1:Activity .

cdm1:performedBy  rdf:type      owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:AgentObjectProperty;
        owl:inverseOf       cdm1:performs .

cdm1:AgentThing  rdf:type    owl:Class;
        skos:definition  "Added for organizational purposes, to identify all classes defined in the Agent pattern.";
        rdfs:subClassOf  cdm1:FoundationalCdmThing .

cdm1:Agent  rdf:type         owl:Class;
        skos:definition  "An Agent affects, is affected by, or performs some Activity(s). An Agent may be a Person or Organization, but not Software or a Mechanical Device (at this time). An Agent can be a member of an organization and hold zero or more posts in an organization.";
        rdfs:subClassOf  cdm1:AgentThing;
        rdfs:subClassOf  <http://xmlns.com/foaf/0.1/Agent>;
        rdfs:subClassOf  <http://www.w3.org/ns/prov#Agent>;
        rdfs:subClassOf  _:b0 .

_:b0    rdf:type           owl:Restriction;
        owl:onProperty     cdm1:performs;
        owl:allValuesFrom  cdm1:Activity .

cdm1:Agent  rdfs:subClassOf  _:b1 .

_:b1    rdf:type           owl:Restriction;
        owl:onProperty     cdm1:resourceOf;
        owl:allValuesFrom  cdm1:TerminalResourceState .

cdm1:Agent  rdfs:subClassOf  _:b2 .

_:b2    rdf:type                  owl:Restriction;
        owl:onProperty            cdm1:hasName;
        owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger;
        owl:onDataRange           xsd:string .
