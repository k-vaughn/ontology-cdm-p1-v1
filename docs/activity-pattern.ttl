@prefix cc: <http://creativecommons.org/ns#> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <https://w3id.org/citydata/part1/v1/> .
<https://w3id.org/citydata/part1/v1/ActivityPattern/>  rdf:type  owl:Ontology;
        dcterms:title                  "Information technology - City data model - Part 1: Foundation level concepts - Activity Pattern";
        dcterms:alternative            "CDM Activity Pattern";
        skos:definition                "This ontology specifies the foundation-level concepts related to the activity pattern of the city data model.";
        vann:preferredNamespaceUri     "https://w3id.org/citydata/part1/v1/";
        vann:preferredNamespacePrefix  "cdm1";
        dcterms:creator                "Megan Katsumi";
        dcterms:creator                "Mark Fox";
        dcterms:creator                "Kenneth Vaughn";
        rdfs:comment                   "The prior version of this ontology used a different ontology IRI. This update remains semantically consistent with the version adopted as ISO 5087-1:2023.";
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/Activity/>;
        dcterms:modified               "2026-02-12"^^xsd:date;
        owl:versionInfo                "1.3.0";
        owl:versionIRI                 <ActivityPattern/r3.0/>;
        cc:license                     "http://creativecommons.org/licenses/by/4.0/";
        owl:imports <https://w3id.org/citydata/part1/v1/ChangePattern> ;
        owl:imports <https://w3id.org/citydata/part1/v1/SpatialLocPattern/> .

cdm1:ActivityObjectProperty
        rdf:type            owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:FoundationalCdmObjectProperty;
        skos:definition     "Added for organizational purposes, to identify all activity object properties defined in the City Data Model." .

cdm1:achievedAt  rdf:type           owl:ObjectProperty;
        skos:definition         "Identifies the time Interval or Instant during which the State was satisfied.";
        rdfs:subPropertyOf      cdm1:ActivityObjectProperty;
        rdfs:domain             cdm1:State;
        rdfs:range              time:TemporalEntity;
        owl:propertyChainAxiom  _:b0 .

_:b0    rdf:first  _:b1 .

_:b1    owl:inverseOf  cdm1:effectOf .

_:b0    rdf:rest  _:b2 .

_:b2    rdf:first  cdm1:endOf;
        rdf:rest   rdf:nil .

cdm1:achievedAt  owl:propertyChainAxiom  _:b3 .

_:b3    rdf:first  _:b4 .

_:b4    owl:inverseOf  cdm1:hasDecomp .

_:b3    rdf:rest  _:b5 .

_:b5    rdf:first  cdm1:conjunctiveAchievedAt;
        rdf:rest   _:b6 .

_:b6    rdf:first  time:intervalDuring;
        rdf:rest   rdf:nil .

cdm1:achievedAt  owl:propertyChainAxiom  _:b7 .

_:b7    rdf:first  _:b8 .

_:b8    owl:inverseOf  cdm1:preconditionOf .

_:b7    rdf:rest  _:b9 .

_:b9    rdf:first  cdm1:beginOf;
        rdf:rest   rdf:nil .

cdm1:beginOf  rdf:type              owl:ObjectProperty;
        skos:definition         "Identifies the time Instant at which the Activity occurs.";
        rdfs:subPropertyOf      cdm1:ActivityObjectProperty;
        rdfs:domain             cdm1:Activity;
        rdfs:range              time:Instant;
        owl:propertyChainAxiom  _:b10 .

_:b10   rdf:first  cdm1:occursAt;
        rdf:rest   _:b11 .

_:b11   rdf:first  time:hasBeginning;
        rdf:rest   rdf:nil .

cdm1:causedByActivity  rdf:type  owl:ObjectProperty;
        skos:definition     "Identifies an Activity that in some (indirect) way caused the State to be realized. The causedByActivity property is the inverse of the causes property and is a generalization (super-property) of the effectOf property.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:State;
        rdfs:range          cdm1:Activity;
        owl:inverseOf       cdm1:causesState .

cdm1:causesState  rdf:type      owl:ObjectProperty;
        skos:definition     "identifies a State that in some (indirect) way was caused by the occurrence of the Activity. An Activity is caused by a State if the State is an effect of the Activity or if the State is an effect of some subactivity of the Activity. The causes property is a generalization (super-property) of the hasEffect property.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:Activity;
        rdfs:range          cdm1:State .

cdm1:conjunctiveAchievedAt
        rdf:type            owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:achievedAt;
        rdfs:domain         cdm1:ConjunctiveState .

cdm1:disjunctiveAchievedAt
        rdf:type            owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:achievedAt;
        rdfs:domain         cdm1:DisjunctiveState .

cdm1:effectOf  rdf:type         owl:ObjectProperty;
        skos:definition     "Identifies an Activity that the State was realized by.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:State;
        rdfs:range          cdm1:Activity;
        owl:inverseOf       cdm1:hasEffect .

cdm1:enabledByState  rdf:type   owl:ObjectProperty;
        skos:definition     "Identifies a State that in some (indirect) way enabled the Activity to occur. An Activity is enabled by a State if the State is a precondition for the Activity or if the State is a precondition of some subactivity of the Activity. The enabledByState property is a generalization (super-property) of the hasPrecondition property.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:Activity;
        rdfs:range          cdm1:State;
        owl:inverseOf       cdm1:enablesActivity .

cdm1:enablesActivity  rdf:type  owl:ObjectProperty;
        skos:definition     "Identifies an Activity that in some (indirect) way was enabled by the State. The enables property is the inverse of the enabledByState property and is a generalization (super-property) of the preconditionOf property.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:State;
        rdfs:range          cdm1:Activity .

cdm1:endOf  rdf:type                owl:ObjectProperty;
        skos:definition         "Identifies the time Instant at which the Activity ends.";
        rdfs:subPropertyOf      cdm1:ActivityObjectProperty;
        rdfs:domain             cdm1:Activity;
        rdfs:range              time:Instant;
        owl:propertyChainAxiom  _:b12 .

_:b12   rdf:first  cdm1:occursAt;
        rdf:rest   _:b13 .

_:b13   rdf:first  time:hasEnd;
        rdf:rest   rdf:nil .

cdm1:hasDecomp  rdf:type        owl:ObjectProperty;
        skos:definition     "Identifies two or more States into which the State may be immediately decomposed, i.e. its direct children.";
        rdfs:subPropertyOf  cdm1:hasSubstate .

cdm1:hasEffect  rdf:type        owl:ObjectProperty;
        skos:definition     "Identifies a State that is realized once the Activity has occurred.";
        rdfs:subPropertyOf  cdm1:causesState .

cdm1:hasPrecondition  rdf:type  owl:ObjectProperty;
        skos:definition     "Identifies a State that must be realized in order for the Activity to occur.";
        rdfs:subPropertyOf  cdm1:enabledByState;
        owl:inverseOf       cdm1:preconditionOf .

cdm1:hasStatus  rdf:type        owl:ObjectProperty;
        skos:definition     "Identifies the status of the parent Thing at some point or interval in time.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty .

cdm1:hasSubactivity  rdf:type   owl:ObjectProperty;
        skos:definition     "Identifies a more granular Activity into which the Activity may be decomposed.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:Activity;
        rdfs:range          cdm1:Activity .

cdm1:hasSubstate  rdf:type      owl:ObjectProperty;
        skos:definition     "Identifies a State into which the complex state decomposes, at any level (i.e. its child state, grandchild state, etc.). The hasSubState property is transitive and a super-property of the hasDecomp property.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:NonTerminalState;
        rdfs:range          cdm1:State;
        rdf:type            owl:TransitiveProperty .

cdm1:occursAfter  rdf:type      owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        owl:inverseOf       cdm1:occursBefore .

cdm1:occursAt  rdf:type         owl:ObjectProperty;
        skos:definition     "Identifies a time Interval over which the Activity occurs.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:Activity;
        rdfs:range          time:Interval .

cdm1:occursBefore  rdf:type     owl:ObjectProperty;
        skos:definition     "Identifies an Activity that the Activity occurred before.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:Activity;
        rdfs:range          cdm1:Activity;
        rdf:type            owl:TransitiveProperty;
        rdfs:comment        "An activity occursBefore another if its endOf instant is before the beginOf instant of the other activity; the occursBefore relation is transitive. We cannot define this semantics in OWL, though it could be captured in future work by an extension with rules." .

cdm1:occursDirectlyAfter  rdf:type  owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:occursAfter;
        owl:inverseOf       cdm1:occursDirectlyBefore .

cdm1:occursDirectlyBefore
        rdf:type            owl:ObjectProperty;
        skos:definition     "Identifies an Activity that occurred immediately prior to the Activity. The occursDirectlyBefore property is a sub-property of the occursBefore property.";
        rdfs:subPropertyOf  cdm1:occursBefore;
        rdfs:domain         cdm1:Activity;
        rdfs:range          cdm1:Activity;
        rdfs:comment        "An activity occursDirectlyBefore another if it occursAt an interval that meets the interval of the other activity. We cannot define this semantics in OWL, though it could be captured by an extension with rules." .

cdm1:preconditionOf  rdf:type   owl:ObjectProperty;
        skos:definition     "Identifies an Activity that requires the State to be realized in order to occur.";
        rdfs:subPropertyOf  cdm1:enablesActivity;
        rdfs:domain         cdm1:State;
        rdfs:range          cdm1:Activity .

cdm1:satisfiedBy  rdf:type      owl:ObjectProperty;
        skos:definition     "Specifies the Manifestation that is to be satisfied (i.e., realized).";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:domain         cdm1:ManifestationState;
        rdfs:range          cdm1:Manifestation .

cdm1:scheduledFor  rdf:type     owl:ObjectProperty;
        skos:definition     "Identifies a time Interval during which a Thing occurs.";
        rdfs:subPropertyOf  cdm1:ActivityObjectProperty;
        rdfs:range          time:Interval .

cdm1:terminalAchievedAt  rdf:type  owl:ObjectProperty;
        rdfs:subPropertyOf  cdm1:achievedAt;
        rdfs:domain         cdm1:TerminalState .

cdm1:ActivityThing  rdf:type  owl:Class;
        skos:definition  "Added for organizational purposes, to identify all classes defined in the Activity pattern.";
        rdfs:subClassOf  cdm1:FoundationalCdmThing .

cdm1:Activity  rdf:type      owl:Class;
        skos:definition  "An Activity describes something that occurs in the domain.\nAn Activity may be further defined by (decomposed into) Subactivities.\nAn Activity may have precondition and/or effect State.\nAn Activity may be enabled by or cause some State. An enabling of causing state is a generalization of a precondition/effect; an Activity is enabled by or causes some State if it has a subactivity with a precondition or effect (respectively) of that State. \nIn other words, the state may not be required directly before, or cause directly after the activity, but by some more specialized sub-activity.\nAn Activity occurs at some point in time and space.\nAn Activity takes place during some interval, and so has some duration.\nAn Activity may have some Manifestations that participate in it.";
        rdfs:subClassOf  cdm1:ActivityThing;
        rdfs:subClassOf  <http://www.w3.org/ns/prov#Activity>;
        rdfs:subClassOf  _:b14 .

_:b14   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:hasSubactivity;
        owl:allValuesFrom  cdm1:Activity .

cdm1:Activity  rdfs:subClassOf  _:b15 .

_:b15   rdf:type                  owl:Restriction;
        owl:onProperty            cdm1:hasStatus;
        owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger;
        owl:onClass               cdm1:ActivityStatus .

cdm1:Activity  rdfs:subClassOf  _:b16 .

_:b16   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:hasPrecondition;
        owl:allValuesFrom  cdm1:State .

cdm1:Activity  rdfs:subClassOf  _:b17 .

_:b17   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:enabledByState;
        owl:allValuesFrom  cdm1:State .

cdm1:Activity  rdfs:subClassOf  _:b18 .

_:b18   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:hasEffect;
        owl:allValuesFrom  cdm1:State .

cdm1:Activity  rdfs:subClassOf  _:b19 .

_:b19   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:causesState;
        owl:allValuesFrom  cdm1:State .

cdm1:Activity  rdfs:subClassOf  _:b20 .

_:b20   rdf:type                  owl:Restriction;
        owl:onProperty            cdm1:scheduledFor;
        owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger;
        owl:onClass               time:Interval .

cdm1:Activity  rdfs:subClassOf  _:b21 .

_:b21   rdf:type            owl:Restriction;
        owl:onProperty      cdm1:occursAt;
        owl:someValuesFrom  time:Interval .

cdm1:Activity  rdfs:subClassOf  _:b22 .

_:b22   rdf:type            owl:Restriction;
        owl:onProperty      cdm1:beginOf;
        owl:someValuesFrom  time:Instant .

cdm1:Activity  rdfs:subClassOf  _:b23 .

_:b23   rdf:type            owl:Restriction;
        owl:onProperty      cdm1:endOf;
        owl:someValuesFrom  time:Instant .

cdm1:Activity  rdfs:subClassOf  _:b24 .

_:b24   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:associatedLocation;
        owl:allValuesFrom  cdm1:Location .

cdm1:Activity  rdfs:subClassOf  _:b25 .

_:b25   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:occursBefore;
        owl:allValuesFrom  cdm1:Activity .

cdm1:Activity  rdfs:subClassOf  _:b26 .

_:b26   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:occursDirectlyBefore;
        owl:allValuesFrom  cdm1:Activity .

cdm1:ActivityStatus  rdf:type  owl:Class;
        skos:definition  "The status of the Activity.";
        rdfs:subClassOf  cdm1:ActivityThing .

cdm1:ConjunctiveState  rdf:type  owl:Class;
        skos:definition   "A type of NonTerminalState that is defined by the conjunction of its child States.";
        rdfs:subClassOf   cdm1:NonTerminalState;
        owl:disjointWith  cdm1:DisjunctiveState .

cdm1:DisjunctiveState  rdf:type  owl:Class;
        skos:definition  "A type of NonTerminalState that is defined by the disjunction of its child States. A State cannot be both conjunctive and disjunctive. ";
        rdfs:subClassOf  cdm1:NonTerminalState .

cdm1:ManifestationState  rdf:type  owl:Class;
        skos:definition  "A specialization of TerminalState, the ManifestationState specifies a Manifestation class that an individual must satisfy in order for the ManifestationState to be true.";
        rdfs:subClassOf  cdm1:TerminalState;
        rdfs:subClassOf  _:b27 .

_:b27   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:satisfiedBy;
        owl:allValuesFrom  cdm1:Manifestation .

cdm1:NonTerminalState  rdf:type  owl:Class;
        skos:definition   "A NonTerminalState has child States (a.k.a., sub-states) that are either conjuctive or disjunctive. Each child may be a TerminalState or NonTerminalState; eventually a TerminalState is reached. A State cannot be both non-terminal and terminal.";
        rdfs:subClassOf   cdm1:State;
        owl:disjointWith  cdm1:TerminalState;
        rdfs:subClassOf   _:b28 .

_:b28   rdf:type                     owl:Restriction;
        owl:onProperty               cdm1:hasDecomp;
        owl:minQualifiedCardinality  "2"^^xsd:nonNegativeInteger;
        owl:onClass                  cdm1:State .

cdm1:NonTerminalState  rdfs:subClassOf  _:b29 .

_:b29   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:hasSubstate;
        owl:allValuesFrom  cdm1:State .

cdm1:NonTerminalState  rdfs:comment  "hasDecomp is not a transitive relation, it only refers to the direct children of a non-terminal state type. A more general relation that is transitive is the substate relation." .

cdm1:State  rdf:type         owl:Class;
        skos:definition  "A State describes some situation in the world which may or may not be satisfied (true) at a given point in time. A State refers to a class of manifestations. It may be a precondition or effect of some Activity, or more generally it may be enabled or be caused by some Activity. If a state is complex, it may refer to some combination of classes of manifestations.\n        Example: A shopping activity, Activity-Shop, can require both the VehicleW30LGas state, but also some state wherein the mall is open, OpenMall. Each state is defined separately. The combined state is then defined as the conjunction of the two states. Thus, we could say that the preconditions for Activity-Shop are: precondition(VehicleW30LGas,Activity-Shop) AND  precondition(OpenMall,Activity-Shop). Alternatively, if the preconditions were required disjunctively, we could state: precondition(VehicleW30LGas,Activity-Shop) OR precondition(OpenMall,Activity-Shop).\n        In large and complex domains, there can be cases in which the above approach is undesirable. In particular, due to the complexity of the description that results as the state being described becomes more detailed. In many cases it will be more natural and convenient to be able to refer to a single, aggregate state. We therefore extend the representation of States to capture aggregation, as approached in the concept of state trees introduced by TOVE as a construct for the activity cluster.\n        A State may be either non-terminal or terminal. A terminal state has no child states, and therefore refers directly to a class of manifestations, whereas a non-terminal state has child states, which may define some classes of manifestations, or further define some other complex states.\n            NonTerminalState(x) v TerminalState(x) = State(x)\n        A state  cannot be both non-terminal and terminal.\n            TerminalState disjointWith NonTerminalState";
        rdfs:subClassOf  cdm1:ActivityThing;
        rdfs:subClassOf  _:b30 .

_:b30   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:preconditionOf;
        owl:allValuesFrom  cdm1:Activity .

cdm1:State  rdfs:subClassOf  _:b31 .

_:b31   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:enablesActivity;
        owl:allValuesFrom  cdm1:Activity .

cdm1:State  rdfs:subClassOf  _:b32 .

_:b32   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:effectOf;
        owl:allValuesFrom  cdm1:Activity .

cdm1:State  rdfs:subClassOf  _:b33 .

_:b33   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:causedByActivity;
        owl:allValuesFrom  cdm1:Activity .

cdm1:State  rdfs:subClassOf  _:b34 .

_:b34   rdf:type                     owl:Restriction;
        owl:onProperty               cdm1:scheduledFor;
        owl:maxQualifiedCardinality  "1"^^xsd:nonNegativeInteger;
        owl:onClass                  time:Interval .

cdm1:State  rdfs:subClassOf  _:b35 .

_:b35   rdf:type           owl:Restriction;
        owl:onProperty     cdm1:achievedAt;
        owl:allValuesFrom  time:TemporalEntity .

cdm1:State  rdfs:subClassOf  _:b36 .

_:b36   rdf:type                  owl:Restriction;
        owl:onProperty            cdm1:hasStatus;
        owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger;
        owl:onClass               cdm1:StateStatus .

cdm1:StateStatus  rdf:type   owl:Class;
        rdfs:subClassOf  cdm1:ActivityThing .

cdm1:TerminalState  rdf:type  owl:Class;
        skos:definition  "A terminal state type has no substates (cannot be decomposed). It corresponds to a particular class of manifestations. A terminal state is achieved at some time if and only if there exists a manifestation within its defined classification, that exists at that time.";
        rdfs:subClassOf  cdm1:State .
