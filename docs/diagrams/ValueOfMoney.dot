// Diagram for ValueOfMoney
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		AmountOfMoney [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">AmountOfMoney</TD></TR></TABLE>> URL="../AmountOfMoney" margin=0]
	}
	ValueOfMoney [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ValueOfMoney</TD></TR></TABLE>> URL="../ValueOfMoney" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		MonetaryValue [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">MonetaryValue</TD></TR></TABLE>> URL="../MonetaryValue" margin=0]
	}
	ValueOfMoney -> AmountOfMoney [arrowhead=onormal style=solid]
	ValueOfMoney -> Invis [style=invis]
	Invis -> MonetaryValue [style=invis]
	MonetaryValue [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">MonetaryValue</TD></TR></TABLE>> URL="../MonetaryValue" margin=0]
	ValueOfMoney -> MonetaryValue [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">redefines</TD></TR><TR><TD ALIGN="CENTER">i72:value</TD></TR></TABLE>> arrowhead=normal style=dashed]
}
