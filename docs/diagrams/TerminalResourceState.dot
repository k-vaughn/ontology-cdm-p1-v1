// Diagram for TerminalResourceState
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		ResourceThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ResourceThing</TD></TR></TABLE>> URL="../ResourceThing" margin=0]
		TerminalState [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TerminalState</TD></TR></TABLE>> URL="../TerminalState" margin=0]
	}
	TerminalResourceState [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TerminalResourceState</TD></TR></TABLE>> URL="../TerminalResourceState" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		i72_Quantity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Quantity</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Quantity" margin=0]
		PlannedAllocation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PlannedAllocation</TD></TR></TABLE>> URL="../PlannedAllocation" margin=0]
		Resource [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Resource</TD></TR></TABLE>> URL="../Resource" margin=0]
	}
	TerminalResourceState -> ResourceThing [arrowhead=onormal style=solid]
	TerminalResourceState -> TerminalState [arrowhead=onormal style=solid]
	TerminalResourceState -> Invis [style=invis]
	Invis -> i72_Quantity [style=invis]
	i72_Quantity -> PlannedAllocation [style=invis]
	PlannedAllocation -> Resource [style=invis]
	PlannedAllocation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PlannedAllocation</TD></TR></TABLE>> URL="../PlannedAllocation" margin=0]
	TerminalResourceState -> PlannedAllocation [label=hasAllocation arrowhead=normal style=solid]
	i72_Quantity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Quantity</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Quantity" margin=0]
	TerminalResourceState -> i72_Quantity [label=hasQuantity arrowhead=normal style=solid]
	Resource [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Resource</TD></TR></TABLE>> URL="../Resource" margin=0]
	Resource -> TerminalResourceState [label="inverse resourceOf" arrowhead=inv style=solid]
}
