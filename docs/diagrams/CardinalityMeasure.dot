// Diagram for CardinalityMeasure
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		CityUnitsThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">CityUnitsThing</TD></TR></TABLE>> URL="../CityUnitsThing" margin=0]
		i72_Measure [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Measure</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Measure" margin=0]
	}
	CardinalityMeasure [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">CardinalityMeasure</TD></TR></TABLE>> URL="../CardinalityMeasure" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		i72_Cardinality_unit [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Cardinality_unit</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Cardinality_unit" margin=0]
	}
	CardinalityMeasure -> CityUnitsThing [arrowhead=onormal style=solid]
	CardinalityMeasure -> i72_Measure [arrowhead=onormal style=solid]
	CardinalityMeasure -> Invis [style=invis]
	Invis -> i72_Cardinality_unit [style=invis]
	i72_Cardinality_unit [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Cardinality_unit</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Cardinality_unit" margin=0]
	CardinalityMeasure -> i72_Cardinality_unit [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">redefines</TD></TR><TR><TD ALIGN="CENTER">i72:unit_of_measure</TD></TR></TABLE>> arrowhead=normal style=dashed]
}
