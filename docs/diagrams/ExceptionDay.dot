// Diagram for ExceptionDay
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		RecurringEventThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RecurringEventThing</TD></TR></TABLE>> URL="../RecurringEventThing" margin=0]
	}
	ExceptionDay [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ExceptionDay</TD></TR><TR><TD ALIGN="LEFT">hasName : xsd:string</TD></TR></TABLE>> URL="../ExceptionDay" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		time_GeneralDateTimeDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:GeneralDateTimeDescription</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/GeneralDateTimeDescription" margin=0]
	}
	ExceptionDay -> RecurringEventThing [arrowhead=onormal style=solid]
	ExceptionDay -> Invis [style=invis]
	Invis -> time_GeneralDateTimeDescription [style=invis]
	time_GeneralDateTimeDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:GeneralDateTimeDescription</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/GeneralDateTimeDescription" margin=0]
	ExceptionDay -> time_GeneralDateTimeDescription [label=onDateTimeDescription arrowhead=normal style=solid]
}
