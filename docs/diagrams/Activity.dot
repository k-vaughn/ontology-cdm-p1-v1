// Diagram for Activity
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		ActivityThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ActivityThing</TD></TR></TABLE>> URL="../ActivityThing" margin=0]
		prov_Activity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">prov:Activity</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/prov/latest/Activity" margin=0]
	}
	Activity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Activity</TD></TR></TABLE>> URL="../Activity" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		ActivityStatus [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ActivityStatus</TD></TR></TABLE>> URL="../ActivityStatus" margin=0]
		Location [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Location</TD></TR></TABLE>> URL="../Location" margin=0]
		State [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">State</TD></TR></TABLE>> URL="../State" margin=0]
		time_Instant [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:Instant</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/Instant" margin=0]
		time_Interval [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:Interval</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/Interval" margin=0]
	}
	Activity -> ActivityThing [arrowhead=onormal style=solid]
	Activity -> prov_Activity [arrowhead=onormal style=solid]
	Activity -> Invis [style=invis]
	Invis -> ActivityStatus [style=invis]
	ActivityStatus -> Location [style=invis]
	Location -> State [style=invis]
	State -> time_Instant [style=invis]
	time_Instant -> time_Interval [style=invis]
	Activity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Activity</TD></TR></TABLE>> URL="../Activity" margin=0]
	Activity -> Activity [label=hasSubactivity arrowhead=normal style=solid]
	ActivityStatus [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ActivityStatus</TD></TR></TABLE>> URL="../ActivityStatus" margin=0]
	Activity -> ActivityStatus [label="hasStatus
1" arrowhead=normal style=solid]
	State [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">State</TD></TR></TABLE>> URL="../State" margin=0]
	State -> Activity [label="inverse preconditionOf" arrowhead=inv style=solid]
	State -> Activity [label="inverse enablesActivity" arrowhead=inv style=solid]
	Activity -> State [label=hasEffect arrowhead=normal style=solid]
	Activity -> State [label=causesState arrowhead=normal style=solid]
	time_Interval [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:Interval</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/Interval" margin=0]
	Activity -> time_Interval [label="scheduledFor
1" arrowhead=normal style=solid]
	Activity -> time_Interval [label=occursAt arrowhead=normal style=solid]
	time_Instant [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:Instant</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/Instant" margin=0]
	Activity -> time_Instant [label=beginOf arrowhead=normal style=solid]
	Activity -> time_Instant [label=endOf arrowhead=normal style=solid]
	Location [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Location</TD></TR></TABLE>> URL="../Location" margin=0]
	Activity -> Location [label=associatedLocation arrowhead=normal style=solid]
	Activity -> Activity [label=occursBefore arrowhead=normal style=solid]
	Activity -> Activity [label=occursDirectlyBefore arrowhead=normal style=solid]
}
