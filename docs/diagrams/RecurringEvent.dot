		State [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">State</TD></TR></TABLE>> URL="../State" margin=0]
		time_DayOfWeek [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:DayOfWeek</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/DayOfWeek" margin=0]
		time_GeneralDateTimeDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:GeneralDateTimeDescription</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/GeneralDateTimeDescription" margin=0]
		time_TemporalEntity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:TemporalEntity</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/TemporalEntity" margin=0]
	}
	RecurringEvent -> RecurringEventThing [arrowhead=onormal style=solid]
	RecurringEvent -> Invis [style=invis]
	Invis -> Activity [style=invis]
	Activity -> Location [style=invis]
	Location -> State [style=invis]
	State -> time_DayOfWeek [style=invis]
	time_DayOfWeek -> time_GeneralDateTimeDescription [style=invis]
	time_GeneralDateTimeDescription -> time_TemporalEntity [style=invis]
	State [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">State</TD></TR></TABLE>> URL="../State" margin=0]
	RecurringEvent -> State [label=beginsRecurringState arrowhead=normal style=solid]
	time_TemporalEntity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:TemporalEntity</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/TemporalEntity" margin=0]
	RecurringEvent -> time_TemporalEntity [label=beginsRecurringTime arrowhead=normal style=solid]
	RecurringEvent -> State [label=endsRecurringState arrowhead=normal style=solid]
	RecurringEvent -> time_TemporalEntity [label=endsRecurringTime arrowhead=normal style=solid]
	time_DayOfWeek [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:DayOfWeek</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/DayOfWeek" margin=0]
	RecurringEvent -> time_DayOfWeek [label=hasDayOfWeek arrowhead=normal style=solid]
	Activity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Activity</TD></TR></TABLE>> URL="../Activity" margin=0]
	RecurringEvent -> Activity [label=hasOccurrence arrowhead=normal style=solid]
	RecurringEvent [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RecurringEvent</TD></TR></TABLE>> URL="../RecurringEvent" margin=0]
	RecurringEvent -> RecurringEvent [label=hasSubRecurringEvent arrowhead=normal style=solid]
	time_GeneralDateTimeDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:GeneralDateTimeDescription</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/GeneralDateTimeDescription" margin=0]
	RecurringEvent -> time_GeneralDateTimeDescription [label=onDateTimeDescription arrowhead=normal style=solid]
	n0ad0eb95ba0b4e29ae8e6824f635a381b20 [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1" BGCOLOR="lightyellow"><TR><TD ALIGN="CENTER">«unionOf»</TD></TR></TABLE>> margin=0]
	n0ad0eb95ba0b4e29ae8e6824f635a381b20 -> time_DayOfWeek [label=member arrowhead=normal style=dotted]
	n0ad0eb95ba0b4e29ae8e6824f635a381b20 -> time_TemporalEntity [label=member arrowhead=normal style=dotted]
	RecurringEvent -> n0ad0eb95ba0b4e29ae8e6824f635a381b20 [label=recursAddition arrowhead=normal style=solid]
	n0ad0eb95ba0b4e29ae8e6824f635a381b24 [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1" BGCOLOR="lightyellow"><TR><TD ALIGN="CENTER">«unionOf»</TD></TR></TABLE>> margin=0]
	n0ad0eb95ba0b4e29ae8e6824f635a381b24 -> time_DayOfWeek [label=member arrowhead=normal style=dotted]
	n0ad0eb95ba0b4e29ae8e6824f635a381b24 -> time_TemporalEntity [label=member arrowhead=normal style=dotted]
	RecurringEvent -> n0ad0eb95ba0b4e29ae8e6824f635a381b24 [label=recursExcept arrowhead=normal style=solid]
	Location [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Location</TD></TR></TABLE>> URL="../Location" margin=0]
	RecurringEvent -> Location [label=associatedLocation arrowhead=normal style=solid]
}
