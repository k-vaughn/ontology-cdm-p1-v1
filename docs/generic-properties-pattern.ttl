@prefix cc: <http://creativecommons.org/ns#> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <https://w3id.org/citydata/part1/v1/> .
<https://w3id.org/citydata/part1/v1/GenericPropertiesPattern/>  rdf:type  owl:Ontology;
        dcterms:title                  "Information technology - City data model - Part 1: Foundation level concepts - Generic Properties Pattern";
        dcterms:alternative            "CDM Generic Properties Pattern";
        skos:definition                "This ontology specifies the foundation-level concepts related to the generic properties pattern of the city data model.";
        vann:preferredNamespaceUri     "https://w3id.org/citydata/part1/v1/";
        vann:preferredNamespacePrefix  "cdm1";
        dcterms:creator                "Megan Katsumi";
        dcterms:creator                "Mark Fox";
        dcterms:creator                "Kenneth Vaughn";
        rdfs:comment                   "The prior version of this ontology used a different ontology IRI. This update remains semantically consistent with the version adopted as ISO 5087-1:2023.";
        owl:priorVersion               <https://standards.iso.org/iso-iec/5087/-1/ed-1/en/ontology/GenericProperties/>;
        dcterms:modified               "2026-02-12"^^xsd:date;
        owl:versionInfo                "1.3.0";
        owl:versionIRI                 <GenericPropertiesPattern/r3.0/>;
        cc:license                     "http://creativecommons.org/licenses/by/4.0/";
        owl:imports <https://w3id.org/citydata/part1/v1/Core> .

cdm1:GeneralDataProperty  rdf:type  owl:DatatypeProperty;
        skos:definition     "Added for organizational purposes, to identify object properties defined in the General Properties Pattern of the CDM ontology.";
        rdfs:subPropertyOf  cdm1:FoundationalCdmDataProperty .

cdm1:hasDescription  rdf:type   owl:DatatypeProperty;
        skos:definition     "Descriptive information about an object.";
        rdfs:subPropertyOf  cdm1:GeneralDataProperty .

cdm1:hasIdentifier  rdf:type    owl:DatatypeProperty;
        skos:definition     "Unique identifier for an object.";
        rdfs:subPropertyOf  cdm1:GeneralDataProperty .

cdm1:hasName  rdf:type          owl:DatatypeProperty;
        skos:definition     "Name of an object.";
        rdfs:subPropertyOf  cdm1:GeneralDataProperty .
